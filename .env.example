# Optional but recommended: raises GitHub rate limit from 10/min to 30/min (search API specific)
# Create one at https://github.com/settings/tokens (no scopes needed for public repo search)
GITHUB_TOKEN=

# Optional: raises GitLab rate limit slightly, create at https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=

# Port to run the server on
PORT=3000
